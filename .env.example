# 复制为 .env 并填真实值;.env 不进 Git
# —— 云数据库(外部 MySQL)——
DB_HOST=<RDS内网地址>
DB_PORT=3306
DB_USER=pickcampus
DB_PASSWORD=<云库密码>
DB_NAME=pickcampus
# —— 本机 Redis(默认无密码,不暴露公网)——
REDIS_PASSWORD=
# —— CORS:留空=本地/回显任意;生产填前端页面域名(注意是前端域名,不是 api 子域名)——
# 例:CORS_ALLOW_ORIGINS=https://你的域名,https://xxx.pages.dev
CORS_ALLOW_ORIGINS=
# —— JWT 签名密钥:openssl rand -base64 48 ——
JWT_SECRET=<生成的随机串>
# —— Cloudflare Tunnel token(见 doc/deploy.md §六)——
CF_TUNNEL_TOKEN=<CF Zero Trust 建隧道后复制的 token>
